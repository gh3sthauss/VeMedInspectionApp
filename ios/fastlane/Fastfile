default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Creates a temporary keychain on the CI machine so cert can install
    # the signing certificate without keychain password prompts.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_PATH"],
      in_house: false
    )

    # Import a persistent Apple Distribution certificate instead of
    # calling get_certificates, which mints a brand new certificate every
    # run - each one an orphan the moment the ephemeral runner is torn
    # down, quickly hitting Apple's 2-certificate account cap. This one
    # cert is reused across all runs.
    import_certificate(
      certificate_path: ENV["IOS_CERT_P12_PATH"],
      certificate_password: ENV["IOS_CERT_P12_PASSWORD"],
      keychain_path: File.expand_path("~/Library/Keychains/fastlane_tmp_keychain-db"),
      keychain_password: ""
    )

    get_provisioning_profile(
      app_identifier: "com.mycompany.vemed",
      api_key: api_key
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["APPLE_TEAM_ID"],
      path: "Runner.xcodeproj",
      code_sign_identity: "Apple Distribution",
      profile_name: lane_context[SharedValues::SIGH_NAME]
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.mycompany.vemed" => lane_context[SharedValues::SIGH_NAME]
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
