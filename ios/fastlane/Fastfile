default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Creates a temporary keychain on the CI machine so cert can install
    # the signing certificate without keychain password prompts.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_PATH"],
      in_house: false
    )

    # Apple Distribution certificate + App Store provisioning profile.
    # App Store profiles don't require registered devices, unlike the
    # development profiles Xcode's automatic signing insists on at
    # archive time.
    # setup_ci's temp keychain must be passed explicitly - cert defaults
    # to the login keychain, whose password is unknown on CI runners.
    get_certificates(
      development: false,
      api_key: api_key,
      keychain_path: File.expand_path("~/Library/Keychains/fastlane_tmp_keychain-db"),
      keychain_password: ""
    )

    get_provisioning_profile(
      app_identifier: "com.mycompany.vemed",
      api_key: api_key
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["APPLE_TEAM_ID"],
      path: "Runner.xcodeproj",
      code_sign_identity: "Apple Distribution",
      profile_name: lane_context[SharedValues::SIGH_NAME]
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.mycompany.vemed" => lane_context[SharedValues::SIGH_NAME]
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
